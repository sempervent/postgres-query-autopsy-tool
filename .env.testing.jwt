# Phase 53 — JWT bearer auth for browser E2E (HS256, test-only key). Never production.
# Use: docker compose --env-file .env.testing.jwt up -d --build api web

PQAT_E2E_ENABLED=true

PQAT_AUTH_ENABLED=true
PQAT_AUTH_MODE=JwtBearer

PQAT_JWT_ISSUER=pqat-e2e-jwt
PQAT_JWT_AUDIENCE=pqat-e2e-api
# UTF-8 secret `pqat-jwt-e2e-sign-secret-key-32b` (32 bytes) — HS256
PQAT_JWT_SIGNING_KEY_BASE64=cHFhdC1qd3QtZTJlLXNpZ24tc2VjcmV0LWtleS0zMmI=

# Claims minted in Playwright (must match nothing in API-key seeds)
PQAT_JWT_SUB_A=e2e-jwt-user-a
PQAT_JWT_SUB_B=e2e-jwt-user-b
