# Phase 52 — auth-mode browser E2E (API key + deterministic principals). Testing only; never production.
# Use: docker compose --env-file .env.testing.auth up -d --build api web

PQAT_E2E_ENABLED=true

PQAT_AUTH_ENABLED=true
PQAT_AUTH_MODE=ApiKey

# Must match HeaderName (default X-Api-Key). Playwright injects this header via browser context (not VITE_*).
PQAT_E2E_API_KEY_USER_A=pqat-e2e-key-user-a
PQAT_E2E_USER_ID_A=e2e-user-a
PQAT_E2E_API_KEY_USER_B=pqat-e2e-key-user-b
PQAT_E2E_USER_ID_B=e2e-user-b
PQAT_E2E_API_KEY_USER_C=pqat-e2e-key-user-c
PQAT_E2E_USER_ID_C=e2e-user-c
PQAT_E2E_SHARED_GROUP_ID=e2e-group-research
