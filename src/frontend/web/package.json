{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "volta": {
    "node": "20.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=e2e-smoke",
    "test:e2e:smoke": "playwright test --project=e2e-smoke",
    "test:e2e:copy": "playwright test e2e/persisted-flows.spec.ts --project=e2e-smoke",
    "test:e2e:auth": "playwright test --project=e2e-auth-api-key",
    "test:e2e:api-key": "playwright test --project=e2e-auth-api-key",
    "test:e2e:jwt": "playwright test --project=e2e-auth-jwt",
    "test:e2e:proxy": "playwright test --project=e2e-auth-proxy",
    "test:e2e:visual": "playwright test --project=e2e-visual",
    "test:e2e:visual:update": "playwright test --project=e2e-visual --update-snapshots",
    "test:e2e:docker": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test --project=e2e-smoke",
    "fixtures:sync": "bash ../../../scripts/sync-e2e-fixtures.sh",
    "fixtures:check": "node ../../../scripts/check-e2e-fixtures.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
