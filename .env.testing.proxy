# Phase 54 — Trusted proxy headers auth for browser E2E (test-only identities). Never production.
# Use: docker compose --env-file .env.testing.proxy up -d --build api web
#
# Simulates an edge that set X-PQAT-User / X-PQAT-Groups before traffic reaches the API.
# Playwright injects the same headers on /api/* via page.route (see e2e/auth/installProxyHeadersRoute.ts).

PQAT_E2E_ENABLED=true

PQAT_AUTH_ENABLED=true
PQAT_AUTH_MODE=ProxyHeaders

# Principals for E2E (must not collide with API-key seed user ids if you ever mix stacks)
PQAT_PROXY_USER_ID_A=e2e-proxy-user-a
PQAT_PROXY_USER_ID_B=e2e-proxy-user-b
